POLYMARKET_HOST=https://clob.polymarket.com
GAMMA_HOST=https://gamma-api.polymarket.com
DATA_API_BASE=https://data-api.polymarket.com
POLYGON_CHAIN_ID=137

PRIVATE_KEY=
FUNDER_ADDRESS=
API_KEY=
API_SECRET=
API_PASSPHRASE=

MODE=paper
ENABLE_LIVE_TRADING=false
KILL_SWITCH=false
KILL_SWITCH_FILE=./data/kill_switch

MIN_LIQUIDITY=1000
MAX_SPREAD_BPS=300
MAX_ORDER_SIZE_USD=25
MAX_MARKET_EXPOSURE_USD=100
MAX_TOTAL_EXPOSURE_USD=300
DAILY_LOSS_LIMIT_USD=50
MAX_OPEN_ORDERS=10
DATA_STALENESS_SECONDS=5

MAX_CONSECUTIVE_LOSSES=5
MAX_INTRADAY_DRAWDOWN_USD=75
ADVERSE_FILL_COOLDOWN_SECONDS=300
API_ERROR_THRESHOLD=5

MIN_ORDERBOOK_DEPTH_USD=50
MAX_SLIPPAGE_BPS=50
RISK_PER_TRADE_BPS_MIN=10
RISK_PER_TRADE_BPS_MAX=50
CLOCK_SKEW_MAX_SECONDS=3

DEFAULT_STRATEGY=market_making_passive
LOG_LEVEL=INFO
SQLITE_PATH=./data/bot.db

HEARTBEAT_INTERVAL_SECONDS=30
PAPER_FEE_BPS=20
PAPER_SLIPPAGE_BPS=10
PAPER_ASSUMED_QUEUE_AHEAD=100

HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=5
RATE_LIMIT_PER_SECOND=10

# Multi-market adaptive engine
MULTI_MARKET_MODE=true
UNIVERSE_MAX_MARKETS=200
UNIVERSE_SCAN_PAGES=5
MAX_CONCURRENT_POSITIONS=5
MAX_OPEN_ORDERS_PER_MARKET=2
MIN_TIME_TO_RESOLUTION_MINUTES=5
# Optional: set FAST_RESOLUTION_MAX_MINUTES to cap horizon (omit for no upper bound).
MIN_VOLUME_24H=500
LIVE_ANALYSIS_TOP_N=25
SCORE_MIN_TRADABLE=0.45
MAKER_FIRST_POST_ONLY=true
ALLOW_MARKET_ORDERS=false
MAX_EXPOSURE_GROUP_USD=150
STRATEGY_LOSS_LIMIT_USD=30
ORCHESTRATOR_INTERVAL_SECONDS=45

# V3 — WebSocket (optional; no polling for critical path when enabled)
ENABLE_WS=false
WS_MARKET_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
WS_USER_URL=wss://ws-subscriptions-clob.polymarket.com/ws/user

# V4 — underlying spot for fair value (REST fallback; optional)
ENABLE_SPOT_PRICE_REST=false
SPOT_PRICE_TTL_SECONDS=30

# V4 — RTDS (optional streaming; stub until URL/credentials are set)
ENABLE_RTDS=false
RTDS_WS_URL=
